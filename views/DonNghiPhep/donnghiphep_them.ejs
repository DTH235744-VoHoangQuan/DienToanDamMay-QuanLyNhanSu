<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <title>
        <%= title %> - Trang quản lý nhân sự
    </title>
</head>

<body>
    <div class="container">
        <!-- Menu ngang -->
        <%- include('../GiaoDien/navbar') %>
            <!-- Nội dung chính -->
            <div class="card mt-3">
                <div class="card-header">
                    <%= title %>
                </div>
                <!-- Viết card ở đây -->
                <div class="filter-section shadow-sm">
                    <form action="/donnghiphep/them" method="post" class="needs-validation" novalidate>
                            
                        <!-- Section: Thông tin nhân viên -->
                        <div class="section-title">Thông tin nhân viên</div>
                        <div class="row g-4 mb-4">
                            <div class="col-md-6">
                                <label class="form-label">Mã nhân viên <span class="required-star">(*)</span></label>
                                <input type="text" name="MaNhanVien" class="form-control" placeholder="Ví dụ: NV001" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Họ và tên <span class="required-star">(*)</span></label>
                                <input type="text" name="HoTen" class="form-control" placeholder="Nhập đầy đủ họ tên" required>
                            </div>
                        </div>

                        <!-- Section: Chi tiết nghỉ phép -->
                        <div class="section-title">Chi tiết xin nghỉ</div>
                        <div class="row g-4 mb-4">
                            <div class="col-md-6">
                                <label class="form-label">Loại đơn nghỉ <span class="required-star">(*)</span></label>
                                <select name="LoaiDon" class="form-select" required>
                                    <option value="" disabled selected>-- Chọn loại đơn --</option>
                                    <option value="Nghỉ phép năm">Nghỉ phép năm</option>
                                    <option value="Nghỉ ốm">Nghỉ ốm</option>
                                    <option value="Nghỉ việc riêng">Nghỉ việc riêng</option>
                                    <option value="Nghỉ thai sản">Nghỉ thai sản</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Ngày gửi đơn</label>
                                <input type="date" name="NgayGui" class="form-control bg-light" value="<%= new Date().toISOString().split('T')[0] %>" readonly>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Từ ngày <span class="required-star">*</span></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white"><i class="bi bi-calendar-event"></i></span>
                                    <input type="date" name="TuNgay" id="TuNgay" class="form-control" required>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Đến ngày <span class="required-star">(*)</span></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white"><i class="bi bi-calendar-check"></i></span>
                                    <input type="date" name="DenNgay" id="DenNgay" class="form-control" required>
                                </div>
                            </div>
                            <div class="col-md-12">
                                <label class="form-label">Lý do <span class="required-star">(*)</span></label>
                                <textarea name="LyDo" class="form-control" rows="4" placeholder="Vui lòng nhập chi tiết lý do xin nghỉ..." required></textarea>
                            </div>
                        </div>

                        <!-- Hidden field for initial status -->
                        <input type="hidden" name="TrangThai" value="Chờ duyệt">

                        <div class="d-flex justify-content-end gap-2 pt-3">
                            <button type="reset" class="btn btn-light px-4 border">Làm lại</button>
                            <button type="submit" class="btn btn-primary btn-submit">
                                <i class="bi bi-send-check-fill me-2"></i>Gửi Đơn Xin Nghỉ
                            </button>   
                        </div>
                    </form>
                </div>
            </div>
            <!-- Footer -->
            <%- include('../GiaoDien/footer') %>
    </div>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <!--Script-->
    <%- include('../GiaoDien/javascript') %>
</body>
</html>