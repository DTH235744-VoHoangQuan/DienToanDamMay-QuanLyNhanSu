<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <title>
        <%= title %> - Trang quản lý nhân sự
    </title>
</head>

<body>
    <div class="container">
        <!-- Menu ngang -->
        <%- include('../GiaoDien/navbar') %>
            <!-- Nội dung chính -->
            <div class="card mt-3">
                <div class="card-header">
                    <%= title %>
                </div>
                <!-- Viết card ở đây -->
                 <!-- Bộ lọc dữ liệu -->
                <div class="filter-section shadow-sm">
                    <form action="/donnghiphep" method="GET" class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label small fw-bold">Trạng thái</label>
                            <select name="trangThai" class="form-select form-select-sm">
                                <option value="">-- Tất cả trạng thái --</option>
                                <option value="Chờ duyệt" <%= boLocDaChon.trangThai === 'Chờ duyệt' ? 'selected' : '' %>>Chờ duyệt</option>
                                <option value="Đã duyệt" <%= boLocDaChon.trangThai === 'Đã duyệt' ? 'selected' : '' %>>Đã duyệt</option>
                                <option value="Từ chối" <%= boLocDaChon.trangThai === 'Từ chối' ? 'selected' : '' %>>Từ chối</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small fw-bold">Phòng ban</label>
                            <select name="phongBan" class="form-select form-select-sm">
                                <option value="">-- Tất cả phòng ban --</option>
                                <% phongban.forEach(pb => { %>
                                    <option value="<%= pb._id %>" <%= boLocDaChon.phongBan == pb._id.toString() ? 'selected' : '' %>><%= pb.TenPhongBan %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small fw-bold">Loại đơn</label>
                            <select name="loaiDon" class="form-select form-select-sm">
                                <option value="">-- Tất cả loại --</option>
                                <option value="Nghỉ phép năm" <%= boLocDaChon.loaiDon === 'Nghỉ phép năm' ? 'selected' : '' %>>Nghỉ phép năm</option>
                                <option value="Nghỉ ốm" <%= boLocDaChon.loaiDon === 'Nghỉ ốm' ? 'selected' : '' %>>Nghỉ ốm</option>
                                <option value="Nghỉ việc riêng" <%= boLocDaChon.loaiDon === 'Nghỉ việc riêng' ? 'selected' : '' %>>Nghỉ việc riêng</option>
                                <option value="Nghỉ thai sản" <%= boLocDaChon.loaiDon === 'Nghỉ thai sản' ? 'selected' : '' %>>Nghỉ thai sản</option>
                            </select>
                        </div>
                        <div class="col-md-3 d-flex align-items-end gap-2">
                            <button type="submit" class="btn btn-sm btn-dark w-100"><i class="bi bi-filter"></i> Lọc dữ liệu</button>
                            <a href="/donnghiphep" class="btn btn-sm btn-outline-secondary w-100">Xóa bộ lọc</a>
                        </div>
                    </form>
                </div>

                <!-- Bảng -->
                <div class="card-body table-responsive">
                    <a href="/donnghiphep/them" class="btn btn-primary mb-2"><i class="bi bi-people"></i> Thêm mới</a>
                    <table class="table table-bordered table-hover table-sm mb-0">
                        <thead>
                            <tr>
                                <th width="5%">#</th>
                                <th>Mã nhân viên</th>
                                <th>Tên nhân viên</th>
                                <th>Loại đơn</th>
                                <th>Ngày bắt đầu nghỉ</th>
                                <th>Ngày vào làm</th>
                                <th>Lý do</th>
                                <th>Trạng thái</th>
                                <th>Ngày gửi</th>
                                <th>Người duyệt</th>
                                <!-- Nếu không phải nhân viên thì hiện -->
                                <% if (user && user.QuyenHan !== 'nhanvien') { %>
                                    <th width="5%">Duyệt</th>
                                <% } %>
                                <th width="5%">Xóa</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% var stt=1; %>
                            <% donnghiphep.forEach(dnp=> { %>
                                <tr>
                                    <td class="align-middle"><%= stt++ %></td>
                                    <td class="align-middle"><%= dnp.NhanVienId?.MaNhanVien || 'Null' %></td>
                                    <td class="align-middle"><%= dnp.NhanVienId?.HoTen || 'Không tồn tại' %></td>
                                    <td class="align-middle"><%= dnp.LoaiDon %></td>
                                    <td class="align-middle"><%= dnp.TuNgay.toLocaleDateString('vi-VN') %></td>
                                    <td class="align-middle"><%= dnp.DenNgay.toLocaleDateString('vi-VN') %></td>
                                    <td class="align-middle"><%= dnp.LyDo %></td>
                                    <td class="align-middle">
                                        <% if(dnp.TrangThai == 'Chờ duyệt') { %>
                                            <span class="badge bg-warning text-dark"><i class="bi bi-clock"></i> Chờ duyệt</span>
                                        <% } else if(dnp.TrangThai == 'Đã duyệt') { %>
                                            <span class="badge bg-success"><i class="bi bi-check-circle"></i> Đã duyệt</span>
                                        <% } else { %>
                                            <span class="badge bg-danger"><i class="bi bi-x-circle"></i> Từ chối</span>
                                        <% } %>
                                    </td>
                                    <td class="align-middle"><%= dnp.NgayGui.toLocaleDateString('vi-VN') %></td>
                                    <td class="align-middle">
                                        <%= dnp.NguoiDuyetId ? dnp.NguoiDuyetId.HoTen : "Chờ duyệt" %>
                                    </td>

                                    <% if (user && user.QuyenHan === 'admin') { %>
                                        <td class="align-middle text-center">
                                            <div class="d-flex gap-1 justify-content-center">
                                                <% if(dnp.TrangThai == 'Chờ duyệt') { %>
                                                    <form action="/donnghiphep/duyet/<%= dnp._id %>" method="POST" style="display:inline;">
                                                        <input type="hidden" name="TrangThai" value="Đã duyệt">
                                                        <button class="btn btn-sm btn-outline-success" title="Duyệt đơn"><i class="bi bi-check-lg"></i></button>
                                                    </form>
                                                    <form action="/donnghiphep/duyet/<%= dnp._id %>" method="POST" style="display:inline;">
                                                        <input type="hidden" name="TrangThai" value="Từ chối">
                                                        <button class="btn btn-sm btn-outline-danger" title="Từ chối"><i class="bi bi-x-lg"></i></button>
                                                    </form>
                                                <% } %>
                                            </div>
                                        </td> <% } %>

                                    <td class="align-middle text-center">
                                        <a href="/donnghiphep/xoa/<%= dnp._id %>"
                                        onclick="return confirm('Bạn có muốn xóa đơn của <%= dnp.NhanVienId?.HoTen %> không?');">
                                            <i class="bi bi-trash text-danger"></i>
                                        </a>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            </div>
            <!-- Footer -->
            <%- include('../GiaoDien/footer') %>
    </div>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <!--Script-->
    <%- include('../GiaoDien/javascript') %>
</body>
</html>