<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <title>
        <%= title %>
    </title>
</head>

<body>
    <div class="container">
        <%- include('../GiaoDien/navbar') %>
            <div class="card mt-3">
                <div class="card-header">
                    <%= title %>
                </div>
                <div class="card-body">
                    <form action="/thuongphat/sua/<%= item._id %>" method="post">
                        <!-- Nhân viên -->
                        <div class="mb-3">
                            <label class="form-label fw-bold">Nhân viên</label>
                            <select name="NhanVienId" class="form-select">
                                <% nhanvien.forEach(nv=> { %>
                                    <option value="<%= nv._id %>" <%=String(nv._id)===String(item.NhanVienId)? 'selected' : '' %>><%= nv.HoTen %></option>
                                    <% }) %>
                            </select>
                        </div>
                        <!-- Loại -->
                        <div class="mb-3">
                            <label class="form-label fw-bold">Loại</label>
                            <select name="Loai" class="form-select">
                                <option value="Khen thưởng" <%=item.Loai==='Khen thưởng' ? 'selected' : '' %>>Khen thưởng</option>
                                <option value="Kỷ luật" <%=item.Loai==='Kỷ luật' ? 'selected' : '' %>>Kỷ luật
                                </option></select>
                        </div>

                        <!-- Số tiền -->
                        <div class="mb-3">
                            <label class="form-label fw-bold">Số tiền</label>
                            <input type="number" name="SoTien" class="form-control" min="0" value="<%= item.SoTien %>">
                        </div>

                        <!-- Lý do -->
                        <div class="mb-3">
                            <label class="form-label fw-bold">Lý do</label>
                            <textarea name="LyDo" class="form-control"><%= item.LyDo %></textarea>
                        </div>

                        <!-- Ngày -->
                        <div class="mb-3">
                            <label class="form-label fw-bold">Ngày quyết định</label>
                            <input type="date" name="NgayQuyetDinh" class="form-control"
                                value="<%= new Date(item.NgayQuyetDinh).toISOString().split('T')[0] %>">
                        </div>
                        <!-- Button -->
                        <div class="d-flex justify-content-end gap-2">
                            <a href="/thuongphat" class="btn btn-secondary">Hủy</a>
                            <button class="btn btn-success">Cập nhật</button>
                        </div>
                    </form>
                </div>
            </div>
            <!-- Footer -->
            <%- include('../GiaoDien/footer') %>
    </div>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <!--Script-->
    <%- include('../GiaoDien/javascript') %>
</body>

</html>