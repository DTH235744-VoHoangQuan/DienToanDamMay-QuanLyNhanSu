<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <title>
        <%= title %>
    </title>
</head>

<body>
    <div class="container">
        <%- include('../GiaoDien/navbar') %>
            <div class="card mt-3">
                <div class="card-header">
                    <%= title %>
                </div>
                <div class="card-body table-responsive">
                    <a href="/thuongphat/them" class="btn btn-primary mb-2">
                        <i class="bi bi-plus-circle"></i> Thêm thưởng / phạt
                    </a>
                    <table class="table table-bordered table-hover table-sm align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th>Nhân viên</th>
                                <th>Loại</th>
                                <th>Số tiền</th>
                                <th>Lý do</th>
                                <th>Ngày</th>
                                <th width="5%">Sửa</th>
                                <th width="5%">Xóa</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% let stt=1; %>
                                <% thuongphat.forEach(tp=> { %>
                                    <tr>
                                        <td>
                                            <%= stt++ %>
                                        </td>
                                        <td>
                                            <%= tp.NhanVienId ? tp.NhanVienId.HoTen : '' %>
                                        </td>
                                        <td>
                                            <% if(tp.Loai==='Khen thưởng' ){ %>
                                                <span class="badge bg-success">Khen thưởng</span>
                                                <% } else { %>
                                                    <span class="badge bg-danger">Kỷ luật</span>
                                                    <% } %>
                                        </td>
                                        <td class="text-success fw-bold">
                                            <%= tp.SoTien.toLocaleString('vi-VN') %> vnđ
                                        </td>
                                        <td>
                                            <%= tp.LyDo %>
                                        </td>
                                        <td>
                                            <%= new Date(tp.NgayQuyetDinh).toLocaleDateString('vi-VN') %>
                                        </td>
                                        <td class="text-center">
                                            <a href="/thuongphat/sua/<%= tp._id %>">
                                                <i class="bi bi-pencil-square text-primary"></i>
                                            </a>
                                        </td>
                                        <td class="text-center">
                                            <a href="/thuongphat/xoa/<%= tp._id %>"
                                                onclick="return confirm('Bạn có chắc muốn xóa không?')">
                                                <i class="bi bi-trash text-danger"></i>
                                            </a>
                                        </td>
                                    </tr>
                                    <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
            <!-- Footer -->
            <%- include('../GiaoDien/footer') %>
        </div>
        <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
        <!--Script-->
    <%- include('../GiaoDien/javascript') %>
</body>

</html>