<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />     <!-- Dùng để tìm kiếm nhân viên -->
    <title><%= title %> - Trang quản lý nhân sự</title>
</head>

<body>
<div class="container">

    <!-- Navbar -->
    <%- include('../GiaoDien/navbar') %>

    <div class="card mt-3">

        <!-- Header -->
        <div class="card-header">
            <%= title %>
        </div>

        <!-- FILTER -->
        <div class="card-body border-bottom">
            <form action="/chamcong" method="GET" class="row g-3">

                <!-- Ngày -->
                <div class="col-md-4">
                    <label class="form-label small fw-bold">Ngày chấm công</label>
                    <input type="date"
                           name="ngay"
                           value="<%= boLoc.ngay %>"
                           class="form-control form-control-sm">
                </div>
                <!-- Button -->
                <div class="col-md-4 d-flex align-items-end gap-2">
                    <button class="btn btn-dark btn-sm w-100">
                        <i class="bi bi-filter"></i> Lọc
                    </button>
                    <a href="/chamcong" class="btn btn-outline-secondary btn-sm w-100">
                        Xóa lọc
                    </a>
                </div>

            </form>
        </div>

        <!-- TABLE -->
        <div class="card-body table-responsive">

            <a href="/chamcong/them" class="btn btn-primary mb-2">
                <i class="bi bi-plus-circle"></i> Thêm chấm công
            </a>

            <table class="table table-bordered table-hover table-sm align-middle">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Nhân viên</th>
                        <th>Ngày</th>
                        <th>Giờ vào</th>
                        <th>Giờ ra</th>
                        <th>Trạng thái</th>
                        <th width="8%">Sửa</th>
                        <th width="8%">Xóa</th>
                    </tr>
                </thead>

                <tbody>
                <% var stt = 1; %>
                <% chamcong.forEach(cc => { %>
                    <tr>
                        <td><%= stt++ %></td>
                        <td>
                            <a href="/chamcong/nhanvien/<%= cc.NhanVienId._id %>">
                                <%= cc.NhanVienId ? cc.NhanVienId.HoTen : '' %>
                            </a>
                        </td>
                        <td><%= cc.NgayChamCong.toLocaleDateString('vi-VN') %></td>
                        <td><%= cc.GioVao || '-' %></td>
                        <td><%= cc.GioRa || '-' %></td>
                        <td>
                            <% if(cc.TrangThai && cc.TrangThai.includes('Muộn')) { %>
                                <span class="badge bg-warning text-dark">
                                    <i class="bi bi-exclamation-triangle"></i> <%= cc.TrangThai %>
                                </span>
                            <% } else { %>
                                <span class="badge bg-success">
                                    <i class="bi bi-check-circle"></i> <%= cc.TrangThai || 'Đúng giờ' %>
                                </span>
                            <% } %>
                        </td>

                        <!-- Sửa -->
                        <td class="text-center">
                            <a href="/chamcong/sua/<%= cc._id %>"
                               class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil"></i>
                            </a>
                        </td>

                        <!-- Xóa -->
                        <td class="text-center">
                            <a href="/chamcong/xoa/<%= cc._id %>"
                               onclick="return confirm('Bạn có chắc muốn xóa không?')"
                               class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>

                    </tr>
                <% }) %>
                </tbody>

            </table>

        </div>
    </div>

    <!-- Footer -->
    <%- include('../GiaoDien/footer') %>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<%- include('../GiaoDien/javascript') %>

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
</body>
</html>