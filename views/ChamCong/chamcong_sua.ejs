<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <title>
        <%= title %> - Trang quản lý nhân sự
    </title>
</head>

<body>
    <div class="container">

        <!-- Navbar -->
        <%- include('../GiaoDien/navbar') %>

            <div class="card mt-3">

                <!-- Header -->
                <div class="card-header">
                    <%= title %>
                </div>

                <div class="card-body">

                    <!-- FORM SỬA CHẤM CÔNG -->
                    <form action="/chamcong/sua/<%= chamcong._id %>" method="post" class="needs-validation" novalidate>

                        <div class="row">

                            <!-- Nhân viên -->
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Nhân viên <span class="text-danger">(*)</span></label>

                                <select name="NhanVienId" class="form-select" required>
                                    <% nhanvien.forEach(nv=> { %>
                                        <option value="<%= nv._id %>"
                                            <%=String(nv._id)===String(chamcong.NhanVienId._id) ? 'selected' : '' %>>
                                            <%= nv.MaNhanVien %> - <%= nv.HoTen %>
                                        </option>
                                        <% }) %>
                                </select>

                                <div class="invalid-feedback">Vui lòng chọn nhân viên.</div>
                            </div>

                            <!-- Ngày chấm công -->
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Ngày chấm công <span class="text-danger">(*)</span></label>

                                <input type="date" name="NgayChamCong" class="form-control"
                                    value="<%= new Date(chamcong.NgayChamCong).toISOString().split('T')[0] %>" required />

                                <div class="invalid-feedback">Vui lòng chọn ngày.</div>
                            </div>

                            <!-- Giờ vào -->
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Giờ vào</label>

                                <input type="time" name="GioVao" class="form-control" value="<%= chamcong.GioVao %>" />
                            </div>

                            <!-- Giờ ra -->
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Giờ ra</label>

                                <input type="time" name="GioRa" class="form-control" value="<%= chamcong.GioRa %>" />
                            </div>

                        </div>

                        <!-- Trạng thái -->
                        <div class="mb-3">
                            <label class="form-label fw-bold">Trạng thái</label>

                            <input type="text" name="TrangThai" class="form-control" value="<%= chamcong.TrangThai %>"
                                placeholder="VD: Đúng giờ / Muộn / Về sớm" />
                        </div>

                        <!-- BUTTON -->
                        <div class="mt-4 d-flex gap-2 justify-content-end">

                            <a href="/chamcong" class="btn btn-outline-secondary">
                                <i class="bi bi-x-circle"></i> Hủy
                            </a>

                            <button type="submit" class="btn btn-primary px-4">
                                <i class="bi bi-check-lg"></i> Cập nhật
                            </button>

                        </div>

                    </form>

                </div>
            </div>

            <!-- Footer -->
            <%- include('../GiaoDien/footer') %>

    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <%- include('../GiaoDien/javascript') %>

</body>

</html>