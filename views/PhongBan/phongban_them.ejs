<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <title>
        <%= title %> - Trang quản lý nhân sự
    </title>
</head>

<body>
    <div class="container">
        <!-- Menu ngang -->
        <%- include('../GiaoDien/navbar') %>
            <!-- Nội dung chính -->
            <div class="card mt-3">
                <div class="card-header">
                    <%= title %>
                </div>
                <div class="card-body">
                    <!-- Viết card ở đây -->
                    <form action="/phongban/them" method="post" class="needs-validation" novalidate>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="TenPhongBan" class="form-label">Tên phòng ban <span class="text-danger">(*)</span></label>
                                    <input type="text" class="form-control" id="TenPhongBan" name="TenPhongBan"
                                        placeholder="Nhập tên phòng ban..." required />
                                    <div class="invalid-feedback">Vui lòng nhập tên phòng ban.</div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="TruongPhongId" class="form-label">Trưởng phòng (Có thể bổ nhiệm sau)</label>
                                    <select class="form-select border-primary" id="TruongPhongId" name="TruongPhongId">
                                        <option value="">-- Chọn trưởng phòng --</option>
                                        
                                        <optgroup label="Nhân sự có quyền Quản lý / Admin">
                                            <% nhanvien.forEach(nv => { 
                                                // Lọc dựa trên quyền hạn
                                                if (nv.QuyenHan === 'truongphong' || nv.QuyenHan === 'admin') { 
                                            %>
                                                <option value="<%= nv._id %>">
                                                    <%= nv.MaNhanVien %> - <%= nv.HoTen %> 
                                                    (<%= nv.ChucVuId ? nv.ChucVuId.TenChucVu : nv.QuyenHan %>)
                                                </option>
                                            <% } }) %>
                                        </optgroup>
                                    </select>
                                    <div class="form-text text-muted small">Để trống nếu phòng ban mới chưa có nhân sự quản lý.</div>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="MoTa" class="form-label">Mô tả chức năng / Nhiệm vụ</label>
                            <textarea class="form-control" id="MoTa" name="MoTa" rows="3"
                                placeholder="Nhập mô tả về chức năng, nhiệm vụ của phòng ban này..."></textarea>
                        </div>

                        <div class="mt-4 d-flex gap-2 justify-content-end">
                            <a href="/phongban" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left"></i> Quay lại
                            </a>
                            <button type="reset" class="btn btn-light border">
                                <i class="bi bi-arrow-counterclockwise"></i> Làm lại
                            </button>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-plus-circle"></i> Thêm phòng ban
                            </button>
                        </div>
                    </form>
                </div>
            </div>
            <!-- Footer -->
            <%- include('../GiaoDien/footer') %>
    </div>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <!--Script-->
    <%- include('../GiaoDien/javascript') %>
</body>

</html>