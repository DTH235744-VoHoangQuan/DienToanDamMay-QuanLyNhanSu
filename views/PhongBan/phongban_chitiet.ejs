<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <title>
        <%= title %> - Trang quản lý nhân sự
    </title>
</head>

<body>
    <div class="container">
        <%- include('../GiaoDien/navbar') %>

        <div class="card mt-3 shadow-sm">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-building"></i> <%= title %></h5>
                <a href="/phongban" class="btn btn-light btn-sm"><i class="bi bi-arrow-left"></i> Quay lại</a>
            </div>
            
            <div class="card-body">
                <div class="row mb-4">
                    <div class="col-md-6">
                        <p><strong><i class="bi bi-info-circle"></i> Tên phòng:</strong> <%= phongban.TenPhongBan %></p>
                        <p><strong><i class="bi bi-person-badge"></i> Trưởng phòng:</strong> 
                            <span class="badge bg-success">
                                <%= phongban.TruongPhongId ? phongban.TruongPhongId.HoTen : 'Chưa bổ nhiệm' %>
                            </span>
                        </p>
                    </div>
                    <div class="col-md-6">
                        <p><strong><i class="bi bi-card-text"></i> Mô tả:</strong> <%= phongban.MoTa %></p>
                        <p><strong><i class="bi bi-people-fill"></i> Sĩ số:</strong> <%= nhanvien.length %> nhân viên</p>
                    </div>
                </div>

                <hr>

                <h6 class="fw-bold mb-3 text-secondary">DANH SÁCH NHÂN VIÊN</h6>
                <div class="table-responsive">
                    <table class="table table-bordered table-hover table-sm mb-0">
                        <thead class="table-light">
                            <tr>
                                <th width="5%">#</th>
                                <th width="10%">Mã NV</th>
                                <th>Họ tên</th>
                                <th>Chức vụ</th>
                                <th>Giới tính</th>
                                <th>Số điện thoại</th>
                                <th width="10%" class="text-center">Chi tiết</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if(nhanvien.length > 0) { %>
                                <% var stt=1; %>
                                <% nhanvien.forEach(nv => { %>
                                    <tr>
                                        <td class="align-middle text-center"><%= stt++ %></td>
                                        <td class="align-middle fw-bold"><%= nv.MaNhanVien %></td>
                                        <td class="align-middle">
                                            <div class="d-flex align-items-center">
                                                <% if(nv.AnhDaiDien) { %>
                                                    <img src="/images/<%= nv.AnhDaiDien %>" class="rounded-circle me-2" width="30" height="30" style="object-fit: cover;">
                                                <% } else { %>
                                                    <i class="bi bi-person-circle fs-5 me-2 text-secondary"></i>
                                                <% } %>
                                                <%= nv.HoTen %>
                                            </div>
                                        </td>
                                        <td class="align-middle">
                                            <%= nv.ChucVuId ? nv.ChucVuId.TenChucVu : 'N/A' %>
                                        </td>
                                        <td class="align-middle text-center"><%= nv.GioiTinh %></td>
                                        <td class="align-middle"><%= nv.SoDienThoai %></td>
                                        <td class="align-middle text-center">
                                            <a href="/nhanvien/sua/<%= nv._id %>" class="btn btn-outline-primary btn-sm">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="7" class="text-center text-muted p-3 italic">
                                        Phòng ban này hiện chưa có nhân viên nào.
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <%- include('../GiaoDien/footer') %>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <%- include('../GiaoDien/javascript') %>
</body>

</html>