<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <title>
        <%= title %> - Trang quản lý nhân sự
    </title>
</head>

<body>
    <div class="container">
        <!-- Menu ngang -->
        <%- include('../GiaoDien/navbar') %>
            <!-- Nội dung chính -->
            <div class="card mt-3">
                <div class="card-header">
                    <%= title %>
                </div>
                <div class="card-body">
                    <!-- Viết card ở đây -->
                    <form action="/phongban/sua/<%= phongban._id%>" method="post" class="needs-validation" novalidate>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="TenPhongBan" class="form-label fw-bold">Tên phòng ban <span class="text-danger">(*)</span></label>
                                    <input type="text" class="form-control" id="TenPhongBan" name="TenPhongBan"
                                        value="<%= phongban.TenPhongBan %>" required />
                                    <div class="invalid-feedback">Tên phòng ban không được để trống.</div>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="TruongPhongId" class="form-label fw-bold">Thay đổi Trưởng phòng</label>
                                    <select class="form-select border-success" id="TruongPhongId" name="TruongPhongId">
                                        <option value="">-- Trống / Bãi nhiệm --</option>
                                        
                                        <optgroup label="Nhân sự Quản lý / Admin">
                                            <% nhanvien.forEach(nv => { 
                                                // Lọc: Admin, Trưởng phòng, hoặc người đang là trưởng phòng hiện tại
                                                if (nv.QuyenHan === 'truongphong' || nv.QuyenHan === 'admin' || String(nv._id) === String(phongban.TruongPhongId)) { 
                                            %>
                                                <option value="<%= nv._id %>" 
                                                    <%= String(nv._id) === String(phongban.TruongPhongId) ? 'selected' : '' %>>
                                                    <%= nv.MaNhanVien %> - <%= nv.HoTen %> 
                                                    (<%= nv.ChucVuId ? nv.ChucVuId.TenChucVu : nv.QuyenHan %>)
                                                </option>
                                            <% } }) %>
                                        </optgroup>
                                    </select>
                                    <div class="form-text text-muted small">
                                        Lưu ý: Nếu thay đổi sếp mới, hãy nhớ cập nhật lại phòng ban cho nhân sự đó.
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="MoTa" class="form-label fw-bold">Mô tả chức năng</label>
                            <textarea class="form-control" id="MoTa" name="MoTa" rows="3"><%= phongban.MoTa %></textarea>
                        </div>

                        <div class="mt-4 d-flex gap-2 justify-content-end">
                            <a href="/phongban" class="btn btn-outline-secondary">
                                <i class="bi bi-x-circle"></i> Hủy bỏ
                            </a>
                            <button type="submit" class="btn btn-success px-4">
                                <i class="bi bi-check-lg"></i> Cập nhật phòng ban
                            </button>
                        </div>
                    </form>
                </div>
            </div>
            <!-- Footer -->
            <%- include('../GiaoDien/footer') %>
    </div>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <!--Script-->
    <%- include('../GiaoDien/javascript') %>
</body>

</html>