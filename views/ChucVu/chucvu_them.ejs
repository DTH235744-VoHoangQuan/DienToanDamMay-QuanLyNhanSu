<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <title>
        <%= title %> - Trang quản lý nhân sự
    </title>
</head>

<body>
    <div class="container">
        <!-- Menu ngang -->
        <%- include('../GiaoDien/navbar') %>
            <!-- Nội dung chính -->
            <div class="card mt-3">
                <div class="card-header">
                    <%= title %>
                </div>
                <div class="card-body">
                    <!-- Viết card ở đây -->
                    <form action="/chucvu/them" method="post" class="needs-validation" novalidate>

                        <!-- Quan trọng -> Cho 1 hàng -->
                        <div class="row">
                            <div class="col-md-12">
                                <div class="mb-3">
                                    <label for="TenChucVu" class="form-label">Tên chức vụ <span
                                            class="text-danger">(*)</span></label>
                                    <input type="text" class="form-control" id="TenChucVu" name="TenChucVu"
                                        placeholder="VD: Trưởng phòng kinh doanh" required />
                                    <div class="invalid-feedback">Vui lòng nhập tên chức vụ.</div>
                                </div>
                            </div>
                        </div>

                        <!-- HÀNG 2: Lương cơ bản và Phụ cấp -->
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="LuongCoBan" class="form-label">Lương cơ bản (VNĐ)</label>
                                    <input type="number" class="form-control" id="LuongCoBan" name="LuongCoBan" value="0" min="0" required />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="PhuCap" class="form-label">Phụ cấp (VNĐ)</label>
                                    <input type="number" class="form-control" id="PhuCap" name="PhuCap" value="0" min="0" required />
                                </div>
                            </div>
                        </div>

                        <!-- HÀNG 3: Giờ vào làm và Giờ tan ca -->
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="GioVaoLam" class="form-label">Giờ vào làm</label>
                                    <input type="time" class="form-control" id="GioVaoLam" name="GioVaoLam"
                                        value="08:00" required />
                                    <small class="text-muted">Định dạng mặc định: 08:00 AM</small>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="GioTanCa" class="form-label">Giờ tan ca</label>
                                    <input type="time" class="form-control" id="GioTanCa" name="GioTanCa" value="17:00"
                                        required />
                                    <small class="text-muted">Định dạng mặc định: 17:00</small>
                                </div>
                            </div>
                        </div>

                        <!-- Nút bấm -->
                        <div class="mt-4 d-flex gap-2 justify-content-end border-top pt-3">
                            <button type="reset" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-counterclockwise"></i> Làm lại
                            </button>
                            <button type="submit" class="btn btn-success">
                                <i class="bi bi-plus-circle"></i> Lưu chức vụ
                            </button>
                        </div>
                    </form>
                </div>
            </div>
            <!-- Footer -->
            <%- include('../GiaoDien/footer') %>
    </div>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <!--Script-->
    <%- include('../GiaoDien/javascript') %>
</body>

</html>