<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <title>
        <%= title %> - Trang quản lý nhân sự
    </title>
</head>

<body>
    <div class="container">
        <!-- Menu ngang -->
        <%- include('../GiaoDien/navbar') %>
            <!-- Nội dung chính -->
            <div class="card mt-3">
                <div class="card-header">
                    <%= title %>
                </div>
                <div class="card-body">
                    <!-- Viết card ở đây -->
                    <form action="/nhanvien/sua/<%= nhanvien._id%>" method="post" enctype="multipart/form-data" class="needs-validation" novalidate>
                    <!-- HÀNG 1: Mã nhân viên và Họ tên -->
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="MaNhanVien" class="form-label">Mã nhân viên <span class="text-danger">(*)</span></label>
                                <input type="text" class="form-control bg-light" id="MaNhanVien" name="MaNhanVien"
                                    value="<%= nhanvien.MaNhanVien %>" required readonly />
                                <small class="text-muted">Mã nhân viên không được phép thay đổi.</small>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="HoTen" class="form-label">Họ tên <span class="text-danger">(*)</span></label>
                                <input type="text" class="form-control" id="HoTen" name="HoTen"
                                    value="<%= nhanvien.HoTen %>" required />
                            </div>
                        </div>
                    </div>

                    <!-- HÀNG 2: Email và Số điện thoại -->
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Email</label>
                                <input type="email" name="Email" value="<%= nhanvien.Email %>" class="form-control bg-light" readonly>
                                <small class="text-muted">Email tự động theo chức vụ.</small>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="SoDienThoai" class="form-label">Số điện thoại <span class="text-danger">(*)</span></label>
                                <input type="tel" class="form-control" id="SoDienThoai" name="SoDienThoai"
                                    value="<%= nhanvien.SoDienThoai %>" pattern="0[0-9]{9}" required />
                            </div>
                        </div>
                    </div>

                    <!-- HÀNG 3: Ngày sinh và Giới tính -->
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="NgaySinh" class="form-label">Ngày sinh <span class="text-danger">(*)</span></label>
                                <% var d=new Date(nhanvien.NgaySinh); var ngaySinh=d.toISOString().split('T')[0]; %>
                                    <input type="date" name="NgaySinh" class="form-control" value="<%= ngaySinh %>"
                                        required>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Giới tính <span class="text-danger">(*)</span></label>
                                <div class="d-flex gap-3 pt-2">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="GioiTinh" id="GioiTinh1"
                                            value="Nam" <%=nhanvien.GioiTinh=="Nam" ? "checked" : "" %> required />
                                        <label class="form-check-label" for="GioiTinh1">Nam</label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="GioiTinh" id="GioiTinh0"
                                            value="Nữ" <%=nhanvien.GioiTinh=="Nữ" ? "checked" : "" %> required />
                                        <label class="form-check-label" for="GioiTinh0">Nữ</label>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- HÀNG 4: Phòng ban và Chức vụ -->
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="PhongBanId" class="form-label">Phòng ban <span class="text-danger">(*)</span></label>
                                <select class="form-select" id="PhongBanId" name="PhongBanId" required>
                                    <option value="">-- Chọn --</option>
                                    <% phongban.forEach(pb=> { %>
                                        <option value="<%= pb._id %>" <%=(nhanvien.PhongBanId &&
                                            pb._id.toString()==nhanvien.PhongBanId.toString()) ? "selected" : "" %>>
                                            <%= pb.TenPhongBan %>
                                        </option>
                                    <% }); %>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="ChucVuId" class="form-label">Chức vụ <span class="text-danger">(*)</span></label>
                                <select class="form-select" id="ChucVuId" name="ChucVuId" required>
                                    <option value="">-- Chọn --</option>
                                    <% chucvu.forEach(cv=> { %>
                                        <option value="<%= cv._id %>" <%=(nhanvien.ChucVuId &&
                                            cv._id.toString()==nhanvien.ChucVuId.toString()) ? "selected" : "" %>>
                                            <%= cv.TenChucVu %>
                                        </option>
                                    <% }); %>
                                </select>
                            </div>
                        </div>
                    </div>

                    <!-- HÀNG 5: Quyền hạn và Trạng thái -->
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Hệ Số lương</label>
                                <input type="number" name="HeSoLuong" min="1" max="10" step="0.1" value="<%= nhanvien.HeSoLuong %>" class="form-control bg-light">
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Trạng thái <span class="text-danger">(*)</span></label>
                                <div class="d-flex gap-3 pt-2">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="TrangThai" id="TrangThai1"
                                            value="Đang làm việc" <%=nhanvien.TrangThai=="Đang làm việc" ? "checked" : "" %> required />
                                        <label class="form-check-label" for="TrangThai1">Đang làm việc</label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="TrangThai" id="TrangThai0"
                                            value="Đã nghỉ việc" <%=nhanvien.TrangThai=="Đã nghỉ việc" ? "checked" : "" %> required />
                                        <label class="form-check-label" for="TrangThai0">Đã nghỉ việc</label>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- HÀNG 6: Hệ số lương và Ảnh đại diện -->
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label" for="QuyenHan">Quyền hạn <span class="text-danger">(*)</span></label>
                                <select class="form-select" id="QuyenHan" name="QuyenHan" required>
                                    <option value="nhanvien" <%=nhanvien.QuyenHan=="nhanvien" ? "selected" : "" %>>Nhân viên</option>
                                    <option value="truongphong" <%=nhanvien.QuyenHan=="truongphong" ? "selected" : "" %>>Trưởng phòng</option>
                                    <option value="admin" <%=nhanvien.QuyenHan=="admin" ? "selected" : "" %>>Admin</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label" for="AnhDaiDien">Ảnh đại diện</label>
                                <input type="file" class="form-control" id="AnhDaiDien" name="AnhDaiDien"
                                    accept="image/*" />
                                <% if(nhanvien.AnhDaiDien) { %>
                                    <div class="mt-2 d-flex align-items-center gap-2">
                                        <i class="bi bi-image text-primary"></i>
                                        <small class="text-muted">File hiện tại: <strong>
                                                <%= nhanvien.AnhDaiDien %>
                                            </strong></small>
                                    </div>
                                    <% } %>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4 d-flex gap-2 justify-content-end border-top pt-3">
                        <a href="/nhanvien" class="btn btn-outline-secondary">
                            <i class="bi bi-x-circle"></i> Hủy bỏ
                        </a>
                        <button type="submit" class="btn btn-success px-4">
                            <i class="bi bi-check-lg"></i> Cập nhật nhân viên
                        </button>
                    </div>
                    </form>
                </div>
            </div>
            <!-- Footer -->
            <%- include('../GiaoDien/footer') %>
    </div>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <!--Script-->
    <%- include('../GiaoDien/javascript') %>
</body>

</html>