<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <title>
        <%= title %> - Trang quản lý nhân sự
    </title>
</head>

<body>
    <div class="container">
        <!-- Menu ngang -->
        <%- include('../GiaoDien/navbar') %>
            <!-- Nội dung chính -->
            <div class="card mt-3">
                <div class="card-header">
                    <%= title %>
                </div>
                <div class="card-body">
                    <!-- Viết card ở đây -->
                    <% if (typeof error !== 'undefined' && error) { %>
                        <div class="alert alert-danger alert-dismissible fade show">
                            <i class="bi bi-exclamation-octagon-fill"></i> <%= error %>
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    <% } %>
                    <form action="/nhanvien/them" method="post" enctype="multipart/form-data" class="needs-validation" novalidate>
                    
                    <!-- HÀNG 1: Mã nhân viên và Họ tên -->
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="MaNhanVien" class="form-label">Mã nhân viên <span class="text-danger">(*)</span></label>
                                <input type="text" class="form-control" id="MaNhanVien" name="MaNhanVien" placeholder="Nhập mã số nhân viên..."required />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="HoTen" class="form-label">Họ tên <span class="text-danger">(*)</span></label>
                                <input type="text" class="form-control" id="HoTen" name="HoTen" 
                                    value="<%= typeof oldData !== 'undefined' ? oldData.HoTen : '' %>" placeholder="Nhập họ tên nhân viên..."required>
                            </div>
                        </div>
                    </div>

                    <!-- HÀNG 2: Số điện thoại và Ngày sinh -->
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="SoDienThoai" class="form-label">Số điện thoại <span class="text-danger">(*)</span></label>
                                <input type="tel" class="form-control" id="SoDienThoai" name="SoDienThoai" pattern="0[0-9]{9}" 
                                    value="<%= typeof oldData !== 'undefined' ? oldData.SoDienThoai : '' %>" placeholder="Nhập số điện thoại..." required />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="NgaySinh" class="form-label">Ngày sinh <span class="text-danger">(*)</span></label>
                                <input type="date" name="NgaySinh" class="form-control" 
                                    value="<%= typeof oldData !== 'undefined' ? oldData.NgaySinh : '' %>" required>
                            </div>
                        </div>
                    </div>

                    <!-- HÀNG 3: Giới tính và Ảnh đại diện -->
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Giới tính <span class="text-danger">(*)</span></label>
                                <div class="d-flex gap-3">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="GioiTinh" id="GioiTinh1" value="Nam" checked required />
                                        <label class="form-check-label" for="GioiTinh1">Nam</label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="GioiTinh" id="GioiTinh0" value="Nữ" required />
                                        <label class="form-check-label" for="GioiTinh0">Nữ</label>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Hệ Số lương</label>
                                <input type="number" name="HeSoLuong" min="1" max="10" step="0.1" value="" class="form-control bg-light" >
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label" for="AnhDaiDien">Ảnh đại diện</label>
                                <input type="file" class="form-control" id="AnhDaiDien" name="AnhDaiDien" accept="image/*" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="PhongBanId" class="form-label">Phòng ban <span class="text-danger">(*)</span></label>
                                <select class="form-select" id="PhongBanId" name="PhongBanId" required>
                                    <option value="">-- Chọn --</option>
                                    <% phongban.forEach(pb => { %>
                                        <option value="<%= pb._id %>" 
                                            <%= (typeof oldData !== 'undefined' && oldData.PhongBanId == pb._id.toString()) ? 'selected' : '' %>>
                                            <%= pb.TenPhongBan %>
                                        </option>
                                    <% }) %>
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="ChucVuId" class="form-label">Chức vụ <span class="text-danger">(*)</span></label>
                                <select class="form-select" id="ChucVuId" name="ChucVuId" required>
                                    <option value="">-- Chọn --</option>
                                    <% chucvu.forEach(cv => { %>
                                        <option value="<%= cv._id %>"
                                            <%= (typeof oldData !== 'undefined' && oldData.ChucVuId == cv._id.toString()) ? 'selected' : '' %>>
                                            <%= cv.TenChucVu %>
                                        </option>
                                    <% }) %>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label" for="QuyenHan">Quyền hạn <span class="text-danger">(*)</span></label>
                                <select class="form-select" id="QuyenHan" name="QuyenHan" required>
                                    <option value="nhanvien" selected>Nhân viên</option>
                                    <option value="truongphong">Trưởng phòng</option>
                                    <option value="admin">Admin</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4 d-flex gap-2 justify-content-end">
                        <button type="reset" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-counterclockwise"></i> Làm lại
                        </button>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-person-plus"></i> Thêm nhân viên
                        </button>
                    </div>
                </form>
                </div>
            </div>
        <!-- Footer -->
        <%- include('../GiaoDien/footer') %>
    </div>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <!--Script-->
    <%- include('../GiaoDien/javascript') %>
</body>

</html>