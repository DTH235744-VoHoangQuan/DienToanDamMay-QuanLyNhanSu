<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <title>
        <%= title %> - Trang quản lý nhân sự
    </title>
</head>

<body>
    <div class="container">
        <!-- Menu ngang -->
        <%- include('../GiaoDien/navbar') %>
            <!-- Nội dung chính -->
            <div class="card mt-3">
                <div class="card-header">
                    <%= title %>
                </div>
                <!-- Viết card ở đây -->
                <div class="card-body table-responsive">
                    <a href="/nhanvien/them" class="btn btn-primary mb-2"><i class="bi bi-people"></i> Thêm mới</a>
                    <table class="table table-bordered table-hover table-sm mb-0">
                        <thead>
                            <tr>
                                <th width="5%">#</th>
                                <th>Hình ảnh</th>
                                <th>Mã số</th>
                                <th>Họ tên</th>
                                <th>Email</th>
                                <!-- <th>Mật khẩu</th> -->
                                <th>SĐT</th>
                                <th>Ngày sinh</th>
                                <th>Giới tính</th>
                                <th>Phòng ban</th>
                                <th>Chức vụ</th>
                                <th>Hệ số lương</th>
                                <th>Quyền hạn</th>
                                <th>Trạng thái</th>
                                <th width="5%">Sửa</th>
                                <th width="5%">Xóa</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% var stt=1; %>
                                <% nhanvien.forEach(nv=> { %>
                                    <tr>
                                        <td class="align-middle">
                                            <%= stt++ %>
                                        </td>
                                        <td class="align-middle">
                                            <% if(nv.AnhDaiDien) { %>
                                                <img src="/images/<%= nv.AnhDaiDien %>"
                                                    style="width: 40px; height: 40px;" class="rounded-circle">
                                                <% } else { %>
                                                    <div class="bg-light d-flex align-items-center justify-content-center rounded-circle"
                                                        style="width: 40px; height: 40px;">
                                                        <i class="bi bi-person text-secondary"></i>
                                                    </div>
                                                    <% } %>
                                        </td>
                                        <td class="align-middle">
                                            <%= nv.MaNhanVien %>
                                        </td>
                                        <td class="align-middle">
                                            <%= nv.HoTen %>
                                        </td>
                                        <td class="align-middle">
                                            <%= nv.Email %>
                                        </td>
                                        <td class="align-middle">
                                            <%= nv.SoDienThoai %>
                                        </td>
                                        <td class="align-middle">
                                            <%= nv.NgaySinh ? new Date(nv.NgaySinh).toLocaleDateString('vi-VN') : '---'
                                                %>
                                        </td>
                                        <td class="align-middle">
                                            <%= nv.GioiTinh %>
                                        </td>
                                        <td class="align-middle">
                                            <%= nv.PhongBanId ? nv.PhongBanId.TenPhongBan : 'Chưa xếp phòng' %>
                                        </td>
                                        <td class="align-middle">
                                            <%= nv.ChucVuId ? nv.ChucVuId.TenChucVu : 'Chưa có chức vụ' %>
                                        </td>
                                        <td class="align-middle">
                                            <%= nv.HeSoLuong ? nv.HeSoLuong : 1 %>
                                        </td>
                                        <td class="align-middle">
                                            <%= nv.QuyenHan %>
                                        </td>
                                        <td class="align-middle">
                                            <% if(nv.TrangThai==='Đang làm việc' ) { %>
                                                <span class="badge rounded-pill bg-success-subtle text-success">Đang làm
                                                    việc</span>
                                                <% } else { %>
                                                    <span class="badge rounded-pill bg-danger-subtle text-danger">Đã
                                                        nghỉ việc</span>
                                                    <% } %>
                                        </td>
                                        <td class="align-middle text-center">
                                            <a href="/nhanvien/sua/<%= nv._id %>"><i
                                                    class="bi bi-pencil-square"></i></a>
                                        </td>
                                        <td class="align-middle text-center">
                                            <a href="/nhanvien/xoa/<%= nv._id %>"
                                                onclick="return confirm('Bạn có muốn xóa nhân viên <%= nv.HoTen %> không?');">
                                                <i class="bi bi-trash text-danger"></i>
                                            </a>
                                        </td>
                                    </tr>
                                    <% }); %>
                        </tbody>
                    </table>
                </div>
            </div>
            <!-- Footer -->
            <%- include('../GiaoDien/footer') %>
    </div>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <!--Script-->
    <%- include('../GiaoDien/javascript') %>
</body>

</html>