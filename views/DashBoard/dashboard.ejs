<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <title>
        <%= title %> - Trang quản lý nhân sự
    </title>
</head>
<body>
    <div class="container">
        <%- include('../GiaoDien/navbar') %>
            <div class="card mt-3">
                <div class="card-header">
                    <%= title %>
                </div>
                <div class="card-body">
                    <!-- FILTER (giống style phòng ban) -->
                    <form method="GET" class="row g-3 mb-3">
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Tháng</label>
                            <input type="number" name="thang" value="<%= thang %>" class="form-control">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Năm</label>
                            <input type="number" name="nam" value="<%= nam %>" class="form-control">
                        </div>
                        <div class="col-md-3 d-flex align-items-end">
                            <button class="btn btn-primary w-100">
                                <i class="bi bi-search"></i> Thống kê
                            </button>
                        </div>
                    </form>
                    <!-- CARDS -->
                    <div class="row">
                        <div class="col-md-3">
                            <div class="card border-primary">
                                <div class="card-body text-center">
                                    <h6 class="text-primary">Tổng nhân viên</h6>
                                    <h3><%= tongNhanVien %></h3>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card border-success">
                                <div class="card-body text-center">
                                    <h6 class="text-success">Tổng phòng ban</h6>
                                    <h3>
                                        <%= tongPhongBan %>
                                    </h3>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card border-warning">
                                <div class="card-body text-center">
                                    <h6 class="text-warning">Tổng lương tháng</h6>
                                    <h4><%= tongLuongThang.toLocaleString('vi-VN') %> đ</h4>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card border-danger">
                                <div class="card-body text-center">
                                    <h6 class="text-danger">Tổng lương năm</h6>
                                    <h4><%= tongLuongNam.toLocaleString('vi-VN') %> đ</h4>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <%- include('../GiaoDien/footer') %>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>